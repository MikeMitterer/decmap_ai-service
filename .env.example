# Database
POSTGRES_URL=postgresql://decisionmap:decisionmap@localhost:5432/decisionmap
POSTGRES_USER=decisionmap
POSTGRES_PASSWORD=decisionmap
POSTGRES_DB=decisionmap

# Provider Selection
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Similarity thresholds
SIMILARITY_THRESHOLD=0.85
DUPLICATE_THRESHOLD=0.92

# Clustering
CLUSTERING_INTERVAL=360

# Bot detection
BOT_SUBMIT_MIN_SECONDS=10
BOT_SESSION_MAX_HOURLY=10
BOT_IP_MAX_SESSIONS=5

# App version (set by Jenkins via hashVer — leave empty for default from pyproject.toml)
APP_VERSION=

# Webhook secret (shared with Directus Flows — leave empty to disable in dev)
WEBHOOK_SECRET=

# CORS — comma-separated list of allowed browser origins
# Lokale Entwicklung via Dev-Proxy: http://int.decisionmap.ai
# Direktzugriff ohne nginx: http://localhost:3000
# Hinweis: Browser-Requests via nginx (/api/*) sind same-origin → kein CORS nötig
CORS_ORIGINS=["http://int.decisionmap.ai"]
